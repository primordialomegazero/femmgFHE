\section{Implementation Guide}
%═══════════════════════════════════════════════════════════

\subsection{Complete Minimal Working Example}

\begin{lstlisting}[style=cppstyle, caption={Complete ZANS + Fibonacci Multiplication Example}]
#include "seal/seal.h"
#include <iostream>
#include <vector>

using namespace seal;

// Fibonacci utilities
std::vector<uint64_t> fib_seq(uint64_t limit) {
    std::vector<uint64_t> f = {1, 2};
    while (f.back() <= limit)
        f.push_back(f[f.size()-1] + f[f.size()-2]);
    f.pop_back();
    return f;
}

std::vector<int> zeck(uint64_t n, const std::vector<uint64_t>& fib) {
    std::vector<int> idx;
    uint64_t r = n;
    for (int i = fib.size()-1; i >= 0 && r > 0; i--)
        if (fib[i] <= r) { idx.push_back(i); r -= fib[i]; }
    return idx;
}

// Encrypt single integer
Ciphertext encrypt_uint(uint64_t v, Encryptor& enc, 
                        BatchEncoder& benc, size_t N) {
    Plaintext p;
    std::vector<uint64_t> vec(N, 0ULL);
    vec[0] = v;
    benc.encode(vec, p);
    Ciphertext ct;
    enc.encrypt(p, ct);
    return ct;
}

// Decrypt to uint64_t
uint64_t decrypt_uint(const Ciphertext& ct, Decryptor& dec,
                      BatchEncoder& benc) {
    Plaintext p;
    dec.decrypt(ct, p);
    std::vector<uint64_t> vec;
    benc.decode(p, vec);
    return vec[0];
}

// ZANS operation
void zans(Ciphertext& ct, const Ciphertext& enc_zero,
          Evaluator& eval) {
    eval.add_inplace(ct, enc_zero);
}

// Fibonacci multiplication
Ciphertext fib_mul(const Ciphertext& base, uint64_t mult,
                   const Ciphertext& enc_zero,
                   Evaluator& eval, Encryptor& enc,
                   BatchEncoder& benc, size_t N) {
    auto fib = fib_seq(1000000);
    auto idx = zeck(mult, fib);
    if (idx.empty()) return encrypt_uint(0, enc, benc, N);
    
    int max_i = idx[0];
    std::vector<Ciphertext> terms(max_i + 1);
    terms[0] = base;
    terms[1] = base;
    eval.add_inplace(terms[1], terms[1]);
    zans(terms[1], enc_zero, eval);
    
    for (int i = 2; i <= max_i; i++) {
        terms[i] = terms[i-1];
        eval.add_inplace(terms[i], terms[i-2]);
        zans(terms[i], enc_zero, eval);
    }
    
    Ciphertext result = terms[idx[0]];
    for (size_t j = 1; j < idx.size(); j++) {
        eval.add_inplace(result, terms[idx[j]]);
        zans(result, enc_zero, eval);
    }
    return result;
}

int main() {
    // Setup SEAL
    size_t N = 16384;
    EncryptionParameters parms(scheme_type::bfv);
    parms.set_poly_modulus_degree(N);
    parms.set_coeff_modulus(CoeffModulus::BFVDefault(N));
    parms.set_plain_modulus(PlainModulus::Batching(N, 20));
    SEALContext ctx(parms);
    
    KeyGenerator kg(ctx);
    PublicKey pk;
    kg.create_public_key(pk);
    
    Encryptor enc(ctx, pk);
    Evaluator eval(ctx);
    Decryptor dec(ctx, kg.secret_key());
    BatchEncoder benc(ctx);
    
    // Pre-compute Enc(0) for ZANS
    auto enc_zero = encrypt_uint(0, enc, benc, N);
    
    // Example: Enc(7) * 42
    auto ct7 = encrypt_uint(7, enc, benc, N);
    auto result = fib_mul(ct7, 42, enc_zero, eval, enc, benc, N);
    
    std::cout << "7 * 42 = " << decrypt_uint(result, dec, benc) << "\n";
    std::cout << "Noise: " << dec.invariant_noise_budget(result) << " bits\n";
    
    return 0;
}
\end{lstlisting}

\subsection{Compilation Instructions}

\begin{lstlisting}[style=cppstyle, caption={Build Commands}]
# Requires: Microsoft SEAL 4.3 installed to /usr/local
g++ -std=c++17 -O2 -march=native \
    your_program.cpp \
    -I /usr/local/include/SEAL-4.3 \
    /usr/local/lib/libseal-4.3.a \
    -pthread \
    -o your_program

./your_program
\end{lstlisting}

\subsection{Optimization Strategies}

\begin{enumerate}[leftmargin=*]
    \item \textbf{Pre-compute $\Enc(0)$:} Generate once, reuse for all ZANS operations. The contraction effect is identical to fresh $\Enc(0)$ each time.
    
    \item \textbf{Cache Fibonacci basis:} If multiplying by the same base value repeatedly, cache the pre-computed Fibonacci terms. Building a 30-term basis takes $\sim 100$ ms and enables $\mathcal{O}(\log_\phi n)$ multiplication for any multiplier up to $\sim 1.3$ million.
    
    \item \textbf{In-place operations:} Use \texttt{add\_inplace} and \texttt{multiply\_plain\_inplace} to avoid ciphertext copies.
    
    \item \textbf{Batch encoding:} Pack multiple values into the polynomial slots. ZANS and Fibonacci operations apply to all slots simultaneously.
    
    \item \textbf{Modulus level management:} If using modulus switching, re-compute $\Enc(0)$ at each level. ZANS contraction rate is consistent across levels.
    
    \item \textbf{Threading:} Independent ZANS operations on different ciphertexts can be parallelized. The operations are purely local to each ciphertext.
\end{enumerate}

\subsection{Performance Tuning Guide}

\begin{table}[H]
\centering
\caption{Performance Tuning Parameters}
\label{tab:tuning}
\begin{tabular}{@{}lp{5cm}p{5cm}@{}}
\toprule
\textbf{Parameter} & \textbf{Trade-off} & \textbf{Recommendation} \\
\midrule
\texttt{poly\_modulus\_degree} & Higher = more security but slower & 16384 for 128-bit security \\
Plaintext modulus bits & More bits = larger values but less noise budget & 20-30 bits for most workloads \\
ZANS frequency & Every op vs every N ops & Every addition for safety \\
Fib cache size & More terms = faster for large multipliers & 30 terms ($\sim 1.3$M max) \\
\bottomrule
\end{tabular}
\end{table}

