\section{Fibonacci-Decomposed Multiplication}
%═══════════════════════════════════════════════════════════

\subsection{Motivation and Design Rationale}

While ZANS provides dramatic noise contraction for addition operations, direct ciphertext-ciphertext multiplication (UK$\times$UK) remains problematic. A single UK$\times$UK multiply consumes approximately $33$ bits of noise budget, and—critically—this \textit{structural} multiplication noise is \textbf{not ZANS-contractable}. Extensive testing (Section 7.3) confirms that neither ZANS, nor multiplicative ZANS (ZANS-M: $\ct \times \Enc(1)$), nor modulus switching, nor hybrid approaches can contract UK$\times$UK noise.

\textbf{The key insight:} Since ZANS is supremely effective for addition ($0.00002$ bits/op) but ineffective for multiplication ($33$ bits/op, not contractable), we should \textit{replace multiplication with addition wherever possible.}

The standard approach to multiplication via addition is repeated addition:
\begin{equation}
\Enc(a) \times b = \underbrace{\Enc(a) + \Enc(a) + \cdots + \Enc(a)}_{b \text{ times}}
\end{equation}

This requires $\mathcal{O}(b)$ additions. For $b = 1{,}000{,}000$, this would require $1{,}000{,}000$ additions, which is computationally prohibitive.

\textbf{Our solution:} Decompose $b$ into Fibonacci numbers via Zeckendorf's theorem, requiring only $\mathcal{O}(\log_\phi b)$ additions.

\subsection{Algorithm Design}

\begin{algorithm}[H]
\caption{Fibonacci-Decomposed Multiplication}
\label{alg:fib-mul}
\begin{algorithmic}[1]
\REQUIRE $\ct_a = \Enc(a)$, plaintext multiplier $b \in \mathbb{Z}^+$
\ENSURE $\ct_{\text{result}} = \Enc(a \times b)$
\STATE \textbf{// Step 1: Zeckendorf decomposition}
\STATE $\{c_i\} \leftarrow \text{Zeckendorf}(b)$ \quad // $b = \sum F_{c_i}$
\STATE $m \leftarrow \max(c_i)$
\STATE \textbf{// Step 2: Build Fibonacci basis via addition}
\STATE $\ct[0] \leftarrow \ct_a$ \quad // $a \times F_0 = a \times 1$
\STATE $\ct[1] \leftarrow \ct_a + \ct_a$ \quad // $a \times F_1 = a \times 2$
\STATE $\text{ZANS}(\ct[1])$
\FOR{$i = 2$ to $m$}
    \STATE $\ct[i] \leftarrow \ct[i-1] + \ct[i-2]$ \quad // $a \times F_i$
    \STATE $\text{ZANS}(\ct[i])$
\ENDFOR
\STATE \textbf{// Step 3: Sum Zeckendorf terms}
\STATE $\ct_{\text{result}} \leftarrow \ct[c_0]$
\FOR{$j = 1$ to $|c| - 1$}
    \STATE $\ct_{\text{result}} \leftarrow \ct_{\text{result}} + \ct[c_j]$
    \STATE $\text{ZANS}(\ct_{\text{result}})$
\ENDFOR
\RETURN $\ct_{\text{result}}$
\end{algorithmic}
\end{algorithm}

\subsection{Complexity Analysis}

\begin{theorem}[Fibonacci Multiplication Complexity]
Algorithm~\ref{alg:fib-mul} computes $\Enc(a) \times b$ using:
\begin{itemize}
    \item $\mathcal{O}(\log_\phi b)$ ciphertext additions
    \item $\mathcal{O}(\log_\phi b)$ ZANS operations
    \item $\mathcal{O}(\log_\phi b)$ ciphertext storage (for the basis)
\end{itemize}
\end{theorem}

\begin{proof}
Zeckendorf's theorem guarantees that any integer $b$ can be represented as a sum of at most $\mathcal{O}(\log_\phi b)$ non-consecutive Fibonacci numbers. The greedy algorithm iterates through $\sim \log_\phi b$ Fibonacci numbers to find the decomposition. Building the basis requires computing $m = \max(c_i)$ terms, where $m \sim \log_\phi b$. Each term requires exactly one addition and one ZANS. Summing the $\mathcal{O}(\log_\phi b)$ Zeckendorf terms requires one addition and one ZANS per term.
\end{proof}

\subsubsection*{Concrete Example: $b = 1{,}000{,}000$}
\begin{itemize}
    \item Zeckendorf decomposition: $1{,}000{,}000 = 832{,}040 + 121{,}393 + 46{,}368 + 144 + 55$ (5 terms)
    \item $\log_\phi(1{,}000{,}000) \approx 30$ (max index needed)
    \item Basis construction: $30$ additions + $30$ ZANS
    \item Final sum: $4$ additions + $4$ ZANS
    \item \textbf{Total: $\sim 34$ additions} versus $1{,}000{,}000$ for naive repeated addition
\end{itemize}

\subsection{Implementation}

\begin{lstlisting}[style=cppstyle, caption={Fibonacci Multiplication — C++ Implementation}]
std::vector<uint64_t> generate_fib(uint64_t limit) {
    std::vector<uint64_t> fib = {1, 2};
    while (fib.back() <= limit) {
        fib.push_back(fib[fib.size()-1] + fib[fib.size()-2]);
    }
    fib.pop_back();
    return fib;
}

std::vector<int> zeckendorf(uint64_t n, 
                            const std::vector<uint64_t>& fib) {
    std::vector<int> indices;
    uint64_t rem = n;
    for (int i = (int)fib.size() - 1; i >= 0 && rem > 0; i--) {
        if (fib[i] <= rem) {
            indices.push_back(i);
            rem -= fib[i];
        }
    }
    return indices;
}

Ciphertext fib_multiply(const Ciphertext& ct_base, 
                        uint64_t multiplier,
                        const Ciphertext& enc_zero,
                        Evaluator& evaluator) {
    auto fib = generate_fib(1000000);
    auto indices = zeckendorf(multiplier, fib);
    if (indices.empty()) return encrypt_int(0);
    
    int max_idx = indices[0];
    std::vector<Ciphertext> terms(max_idx + 1);
    
    // Basis: F_0 and F_1
    terms[0] = ct_base;
    terms[1] = ct_base;
    evaluator.add_inplace(terms[1], terms[1]);
    evaluator.add_inplace(terms[1], enc_zero);
    
    // Basis: F_2 through F_max
    for (int i = 2; i <= max_idx; i++) {
        terms[i] = terms[i-1];
        evaluator.add_inplace(terms[i], terms[i-2]);
        evaluator.add_inplace(terms[i], enc_zero);
    }
    
    // Sum Zeckendorf terms
    Ciphertext result = terms[indices[0]];
    for (size_t j = 1; j < indices.size(); j++) {
        evaluator.add_inplace(result, terms[indices[j]]);
        evaluator.add_inplace(result, enc_zero);
    }
    
    return result;
}
\end{lstlisting}

